# .vscode/

<!DOCTYPE html>
<html lang="da">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>5 år senere - Maribo Mania 2026</title>
    <style>
        :root {
            --filur-red: #ff2e63;
            --filur-yellow: #ffc93c;
            --dark-disco: #1a1a24;
            --text-light: #ffffff;
        }

        body {
            margin: 0;
            padding: 0;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            background: linear-gradient(135deg, var(--filur-red), var(--filur-yellow));
            background-attachment: fixed;
            color: var(--dark-disco);
            display: flex;
            justify-content: center;
        }

        .phone-container {
            width: 100%;
            max-width: 480px;
            min-height: 100vh;
            background: rgba(26, 26, 36, 0.95);
            color: var(--text-light);
            box-shadow: 0 0 30px rgba(0,0,0,0.5);
            padding: 30px 20px;
            box-sizing: border-box;
            text-align: center;
        }

        header {
            margin-bottom: 35px;
            border-bottom: 3px dashed var(--filur-yellow);
            padding-bottom: 20px;
        }

        h1 {
            font-size: 2.8rem;
            margin: 0;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: var(--filur-yellow);
            text-shadow: 3px 3px 0px var(--filur-red);
        }

        .subtitle {
            font-size: 1.2rem;
            color: #a0a0b8;
            margin-top: 8px;
            font-weight: bold;
            letter-spacing: 3px;
            text-transform: uppercase;
        }

        .lyrics-section {
            line-height: 1.8;
            font-size: 1.25rem;
            white-space: pre-line;
            padding-bottom: 60px;
        }

        .verse {
            margin-bottom: 40px;
            color: #e2e2ec;
        }

        .chorus {
            background: linear-gradient(135deg, rgba(255, 46, 99, 0.2), rgba(255, 201, 60, 0.2));
            padding: 25px 15px;
            border-radius: 20px;
            border: 2px solid var(--filur-yellow);
            font-weight: 700;
            margin: 40px 0;
            box-shadow: 0 0 15px rgba(255, 201, 60, 0.2);
            color: var(--filur-yellow);
        }

        .section-tag {
            display: block;
            font-size: 0.85rem;
            text-transform: uppercase;
            color: var(--filur-red);
            background: var(--filur-yellow);
            padding: 2px 10px;
            border-radius: 5px;
            width: fit-content;
            margin: 0 auto 15px auto;
            font-weight: 900;
            letter-spacing: 1px;
            box-shadow: 2px 2px 0px var(--text-light);
        }

        .chorus .section-tag {
            color: var(--filur-yellow);
            background: var(--filur-red


